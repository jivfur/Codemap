{
  "name": "codemap-vscode",
  "displayName": "Codemap",
  "description": "VS Code scaffold for querying the Codemap SQLite index through graph.py",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.90.0"
  },
  "main": "./src/extension.js",
  "categories": [
    "Other"
  ],
  "contributes": {
    "commands": [
      {
        "command": "codemap.indexWorkspace",
        "title": "Codemap: Index Workspace"
      },
      {
        "command": "codemap.searchSymbol",
        "title": "Codemap: Search Symbol"
      },
      {
        "command": "codemap.showSymbolBody",
        "title": "Codemap: Show Symbol Body"
      },
      {
        "command": "codemap.refreshNeighbors",
        "title": "Codemap: Refresh Neighbors"
      },
      {
        "command": "codemap.findSymbol",
        "title": "Repo Graph: Find Symbol"
      },
      {
        "command": "codemap.showImpact",
        "title": "Repo Graph: Show Impact"
      },
      {
        "command": "codemap.reindexWorkspace",
        "title": "Repo Graph: Reindex Workspace"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "codemap.neighborsView",
          "name": "Codemap Neighbors"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "codemap.refreshNeighbors",
          "when": "view == codemap.neighborsView",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "test": "node --test test/*.test.js"
  },
  "license": "MIT"
}
